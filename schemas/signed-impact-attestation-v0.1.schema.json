{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/signed-impact-attestation-v0.1.schema.json",
  "title": "Signed Impact Attestation v0.1",
  "description": "JSON Schema for Signed Impact Attestation v0.1. Defines a minimal, portable, and auditable envelope for attaching cryptographic signatures to an Impact Score Profile.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "attestation_id",
    "spec_version",
    "profile_type",
    "issued_at",
    "subject",
    "issuer",
    "attestation",
    "integrity",
    "signature_policy",
    "signatures"
  ],
  "properties": {
    "attestation_id": {
      "type": "string",
      "description": "Globally unique identifier for this attestation envelope."
    },
    "spec_version": {
      "type": "string",
      "const": "0.1",
      "description": "Version of this specification used to interpret the document."
    },
    "profile_type": {
      "type": "string",
      "const": "signed-impact-attestation",
      "description": "Stable profile discriminator."
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "active",
        "superseded",
        "revoked",
        "disputed"
      ],
      "default": "active",
      "description": "Lifecycle state of this attestation document."
    },
    "issued_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when this attestation was issued."
    },
    "valid_from": {
      "type": "string",
      "format": "date-time",
      "description": "Optional lower bound from which the attestation is intended to be considered valid."
    },
    "expires_at": {
      "type": "string",
      "format": "date-time",
      "description": "Optional expiry time after which the attestation should not be relied on without refresh."
    },
    "revision_of": {
      "type": "string",
      "description": "Optional pointer to a previous attestation superseded by this one."
    },
    "language": {
      "type": "string",
      "default": "en",
      "description": "Primary human language used in rationale and notes."
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "description": "Identifies the exact impact-scored subject being attested.",
      "required": [
        "impact_profile_ref",
        "subject_hash",
        "subject_hash_algorithm"
      ],
      "properties": {
        "impact_profile_ref": {
          "type": "string",
          "description": "Reference, URI, path, or opaque ID of the target Impact Score Profile."
        },
        "ctr_id_ref": {
          "type": "string",
          "description": "Optional CTR-ID reference linked to the same contribution subject."
        },
        "trace_record_ref": {
          "type": "string",
          "description": "Optional trace record reference linked to the same subject."
        },
        "provenance_ref": {
          "type": "string",
          "description": "Optional provenance or lineage reference."
        },
        "subject_locator": {
          "type": "string",
          "description": "Optional dereferenceable locator for retrieving the target profile."
        },
        "subject_hash": {
          "type": "string",
          "description": "Digest of the exact target payload or canonical subject representation."
        },
        "subject_hash_algorithm": {
          "$ref": "#/$defs/hashAlgorithm"
        },
        "subject_version": {
          "type": "string",
          "description": "Optional version label of the target profile."
        },
        "binding_scope": {
          "type": "string",
          "enum": [
            "entire_profile",
            "score_section_only",
            "selected_fields"
          ],
          "default": "entire_profile",
          "description": "Explains which part of the subject payload the binding applies to."
        },
        "selected_field_paths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "description": "Required when binding_scope is selected_fields."
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "binding_scope": {
                "const": "selected_fields"
              }
            },
            "required": [
              "binding_scope"
            ]
          },
          "then": {
            "required": [
              "selected_field_paths"
            ]
          }
        }
      ]
    },
    "issuer": {
      "type": "object",
      "additionalProperties": false,
      "description": "Declares the party that issues the attestation.",
      "required": [
        "issuer_id",
        "issuer_type"
      ],
      "properties": {
        "issuer_id": {
          "type": "string",
          "description": "Stable issuer identifier."
        },
        "issuer_type": {
          "type": "string",
          "enum": [
            "human_reviewer",
            "ai_evaluator",
            "organization",
            "multi_sig_panel",
            "hybrid_committee"
          ],
          "description": "Type of issuing entity."
        },
        "display_name": {
          "type": "string",
          "description": "Human-readable issuer label."
        },
        "public_key_ref": {
          "type": "string",
          "description": "Optional reference to the issuer public key or keyset."
        },
        "existence_proof_ref": {
          "type": "string",
          "description": "Optional reference to an existence proof or credential record."
        },
        "trust_profile_ref": {
          "type": "string",
          "description": "Optional pointer to a trust or reputation profile."
        },
        "contact_ref": {
          "type": "string",
          "description": "Optional contact or resolution endpoint."
        },
        "jurisdiction": {
          "type": "string",
          "description": "Optional jurisdiction or governance domain label."
        }
      }
    },
    "attestation": {
      "type": "object",
      "additionalProperties": false,
      "description": "States what is being claimed about the target impact profile.",
      "required": [
        "attestation_scope",
        "review_status",
        "confidence_level"
      ],
      "properties": {
        "attestation_scope": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "authorship_of_evaluation",
              "integrity_of_score",
              "review_approval",
              "review_rejection",
              "audit_confirmation",
              "dispute_notice",
              "publication_readiness",
              "allocation_input_readiness"
            ]
          },
          "description": "One or more meanings asserted by this attestation."
        },
        "review_status": {
          "type": "string",
          "enum": [
            "asserted",
            "reviewed",
            "approved",
            "rejected",
            "disputed",
            "withdrawn"
          ],
          "description": "Decision state represented by this attestation."
        },
        "confidence_level": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Issuer confidence in the attested statement."
        },
        "rationale": {
          "type": "string",
          "description": "Optional human-readable explanation of why the statement was issued."
        },
        "methodology_ref": {
          "type": "string",
          "description": "Optional reference to the evaluation or review method used."
        },
        "score_snapshot": {
          "type": "object",
          "additionalProperties": false,
          "description": "Optional frozen summary of the evaluated score at signing time.",
          "properties": {
            "overall_score": {
              "type": "number"
            },
            "dimensional_scores": {
              "type": "object",
              "additionalProperties": {
                "type": "number"
              }
            },
            "score_scale": {
              "type": "string",
              "description": "Optional description of the score range, such as 0-1 or 0-100."
            }
          }
        },
        "claims": {
          "type": "array",
          "description": "Optional structured claim list.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "claim_type",
              "value"
            ],
            "properties": {
              "claim_type": {
                "type": "string"
              },
              "value": {
                "type": "string"
              },
              "note": {
                "type": "string"
              }
            }
          }
        },
        "challenge_window": {
          "type": "object",
          "additionalProperties": false,
          "description": "Optional dispute period metadata.",
          "properties": {
            "opens_at": {
              "type": "string",
              "format": "date-time"
            },
            "closes_at": {
              "type": "string",
              "format": "date-time"
            },
            "dispute_endpoint": {
              "type": "string"
            }
          }
        }
      }
    },
    "integrity": {
      "type": "object",
      "additionalProperties": false,
      "description": "Defines how the canonical payload was normalized and hashed before signature.",
      "required": [
        "payload_hash",
        "payload_hash_algorithm",
        "canonicalization_method",
        "payload_scope"
      ],
      "properties": {
        "payload_hash": {
          "type": "string",
          "description": "Digest of the canonicalized attestation payload."
        },
        "payload_hash_algorithm": {
          "$ref": "#/$defs/hashAlgorithm"
        },
        "canonicalization_method": {
          "type": "string",
          "enum": [
            "jcs-rfc8785",
            "yaml-c14n-v1",
            "jsonld-urdna2015",
            "custom"
          ],
          "description": "Canonicalization method used before hashing."
        },
        "custom_canonicalization_ref": {
          "type": "string",
          "description": "Required when canonicalization_method is custom."
        },
        "payload_scope": {
          "type": "string",
          "enum": [
            "all_fields_except_signatures",
            "all_fields_except_signatures_and_transport_metadata",
            "selected_fields"
          ],
          "description": "Explains which part of the envelope was hashed."
        },
        "selected_field_paths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "description": "Required when payload_scope is selected_fields."
        },
        "detached_payload_ref": {
          "type": "string",
          "description": "Optional reference when the signed payload is stored separately."
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "canonicalization_method": {
                "const": "custom"
              }
            },
            "required": [
              "canonicalization_method"
            ]
          },
          "then": {
            "required": [
              "custom_canonicalization_ref"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "payload_scope": {
                "const": "selected_fields"
              }
            },
            "required": [
              "payload_scope"
            ]
          },
          "then": {
            "required": [
              "selected_field_paths"
            ]
          }
        }
      ]
    },
    "signature_policy": {
      "type": "object",
      "additionalProperties": false,
      "description": "Declares the minimum signature requirements for this attestation.",
      "required": [
        "min_signatures",
        "threshold_mode"
      ],
      "properties": {
        "min_signatures": {
          "type": "integer",
          "minimum": 1,
          "description": "Minimum number of valid signatures required."
        },
        "threshold_mode": {
          "type": "string",
          "enum": [
            "any_of",
            "all_of",
            "quorum",
            "weighted"
          ],
          "description": "Policy for satisfying the signature requirement."
        },
        "required_signer_roles": {
          "type": "array",
          "description": "Optional signer roles that must appear among valid signatures.",
          "items": {
            "$ref": "#/$defs/signerRole"
          },
          "uniqueItems": true
        },
        "weighted_threshold": {
          "type": "number",
          "description": "Required when threshold_mode is weighted."
        },
        "duplicate_signer_strategy": {
          "type": "string",
          "enum": [
            "forbid",
            "allow_if_distinct_keys",
            "allow"
          ],
          "default": "forbid"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "threshold_mode": {
                "const": "weighted"
              }
            },
            "required": [
              "threshold_mode"
            ]
          },
          "then": {
            "required": [
              "weighted_threshold"
            ]
          }
        }
      ]
    },
    "signatures": {
      "type": "array",
      "description": "One or more cryptographic signatures over the canonicalized payload.",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "signature_id",
          "signer_id",
          "signer_role",
          "signed_at",
          "signature_suite",
          "signature_value"
        ],
        "properties": {
          "signature_id": {
            "type": "string",
            "description": "Unique identifier for the signature entry."
          },
          "signer_id": {
            "type": "string",
            "description": "Identifier of the signer."
          },
          "signer_role": {
            "$ref": "#/$defs/signerRole"
          },
          "signer_display_name": {
            "type": "string"
          },
          "signer_key_ref": {
            "type": "string",
            "description": "Reference to the signer public key."
          },
          "signer_existence_proof_ref": {
            "type": "string",
            "description": "Optional link to an existence proof for the signer."
          },
          "signed_at": {
            "type": "string",
            "format": "date-time"
          },
          "signature_suite": {
            "type": "string",
            "enum": [
              "ed25519-jcs-2022",
              "ecdsa-p256-sha256-jcs",
              "rsa-pss-sha256-c14n",
              "bbs-2023",
              "custom"
            ]
          },
          "custom_signature_suite_ref": {
            "type": "string",
            "description": "Required when signature_suite is custom."
          },
          "signature_format": {
            "type": "string",
            "enum": [
              "base64",
              "base64url",
              "hex",
              "multibase"
            ],
            "default": "base64url"
          },
          "signature_value": {
            "type": "string",
            "description": "Encoded signature value."
          },
          "key_purpose": {
            "type": "string",
            "enum": [
              "assertion",
              "authentication",
              "delegation",
              "approval"
            ],
            "default": "assertion"
          },
          "covers_payload_hash": {
            "type": "boolean",
            "default": true
          },
          "verification_material_ref": {
            "type": "string",
            "description": "Optional external verification material such as DID document or certificate chain."
          },
          "note": {
            "type": "string"
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "signature_suite": {
                  "const": "custom"
                }
              },
              "required": [
                "signature_suite"
              ]
            },
            "then": {
              "required": [
                "custom_signature_suite_ref"
              ]
            }
          }
        ]
      }
    },
    "evidence": {
      "type": "array",
      "description": "Optional supporting material relevant to the attestation.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "evidence_type",
          "ref"
        ],
        "properties": {
          "evidence_type": {
            "type": "string",
            "enum": [
              "review_log",
              "audit_report",
              "discussion_record",
              "source_snapshot",
              "proof_bundle",
              "external_registry_entry"
            ]
          },
          "ref": {
            "type": "string"
          },
          "hash": {
            "type": "string"
          },
          "hash_algorithm": {
            "$ref": "#/$defs/hashAlgorithm"
          },
          "note": {
            "type": "string"
          }
        },
        "allOf": [
          {
            "if": {
              "required": [
                "hash"
              ]
            },
            "then": {
              "required": [
                "hash_algorithm"
              ]
            }
          }
        ]
      }
    },
    "chain_of_attestation": {
      "type": "array",
      "description": "Optional ordered chain of preceding attestations, approvals, or linked proofs.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "relation",
          "ref"
        ],
        "properties": {
          "relation": {
            "type": "string",
            "enum": [
              "previous_revision",
              "supporting_attestation",
              "supersedes",
              "disputes",
              "derived_from",
              "anchors_to"
            ]
          },
          "ref": {
            "type": "string"
          },
          "hash": {
            "type": "string"
          },
          "hash_algorithm": {
            "$ref": "#/$defs/hashAlgorithm"
          }
        },
        "allOf": [
          {
            "if": {
              "required": [
                "hash"
              ]
            },
            "then": {
              "required": [
                "hash_algorithm"
              ]
            }
          }
        ]
      }
    },
    "governance": {
      "type": "object",
      "additionalProperties": false,
      "description": "Optional governance and policy declarations.",
      "properties": {
        "policy_ref": {
          "type": "string",
          "description": "Reference to governance rules under which the attestation was issued."
        },
        "issuer_commitments": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "auditability_level": {
          "type": "string",
          "enum": [
            "minimal",
            "standard",
            "enhanced",
            "public"
          ]
        },
        "visibility": {
          "type": "string",
          "enum": [
            "private",
            "shared",
            "public"
          ],
          "default": "shared"
        }
      }
    },
    "extensions": {
      "type": "object",
      "description": "Optional vendor- or ecosystem-specific extension container.",
      "additionalProperties": true
    }
  },
  "$defs": {
    "hashAlgorithm": {
      "type": "string",
      "enum": [
        "sha256",
        "sha384",
        "sha512",
        "blake3"
      ]
    },
    "signerRole": {
      "type": "string",
      "enum": [
        "issuer",
        "reviewer",
        "auditor",
        "approver",
        "witness",
        "allocator"
      ]
    }
  }
}
